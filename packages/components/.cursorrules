## 🎯 COMPONENT USAGE GUIDELINES

### 1. Buttons
```tsx
import { Button } from '@lean-ids/components';

<Button
  variant="primary" | "secondary" | "tertiary"
  size="small" | "medium" | "large"
  disabled={false}
  onClick={handleClick}
>
  Button Text
</Button>
```

### 2. Inputs
```tsx
import { Input } from '@lean-ids/components';

<Input
  label="Label"
  placeholder="Placeholder"
  value={value}
  onChange={handleChange}
  error="Error message"
  helperText="Helper text"
/>
```

### 3. Navigation
```tsx
import { SideNavigation } from '@lean-ids/components';

<SideNavigation
  state="collapsed" // Always collapsed by default
  groups={[
    {
      title: "Group Title",
      items: [
        {
          id: "1",
          label: "Item",
          icon: <Icon />,
          active: true,
          onClick: () => {}
        }
      ]
    }
  ]}
  user={{
    name: "User Name",
    subtitle: "user@email.com",
    initials: "UN",
    avatarUrl: "..."
  }}
  isPinned={false}
  onPinChange={(pinned) => console.log(pinned)}
/>
```

